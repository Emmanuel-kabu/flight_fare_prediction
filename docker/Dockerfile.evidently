FROM python:3.11-slim

WORKDIR /workspace

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN pip install --no-cache-dir evidently

EXPOSE 8001

# Mount reports/data into /workspace via docker-compose volumes
CMD ["sh", "-lc", "evidently ui --host 0.0.0.0 --port 8001 --workspace /workspace/evidently_data"]
